# Meta OAuth Configuration
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
NEXT_PUBLIC_META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback
META_APP_SECRET=your_meta_app_secret

# Google OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ZONE_ID=your_zone_id

# Database
DATABASE_URL=your_database_url

# RunPod API (for AI workflows)
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id

# Environment
NODE_ENV=development

# Anthropic API (optional — for AI-generated "How to fix this" recommendations
# under every bad/warn KPI in the dashboard. If absent, the dashboard falls back
# to a static recipe library. Uses Claude Haiku 4.5.)
ANTHROPIC_API_KEY=

# Email alerts (Resend) — for the "Send critical alerts" button on Budget
# Allocation. Without these, the alert endpoint returns a 503 with a helpful
# setup hint. Sign up free at https://resend.com to get an API key, verify a
# sending domain, then put a from-address you've verified in ALERT_FROM_EMAIL.
RESEND_API_KEY=
ALERT_FROM_EMAIL=
